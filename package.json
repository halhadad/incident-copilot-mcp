{
  "name": "incident-copilot-mcp",
  "version": "0.1.0",
  "description": "Read-only production-investigation MCP server: an agent investigates incidents by querying application logs (Loki) and correlating against an operational database (Postgres, read-only).",
  "type": "module",
  "bin": {
    "incident-copilot-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "seed": "tsx seed/index.ts",
    "evals": "tsx evals/runner.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "observability",
    "incident-response",
    "postgres",
    "loki"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "@modelcontextprotocol/sdk": "^1.21.0",
    "dotenv": "^17.4.2",
    "node-sql-parser": "^5.3.14",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
