# Copy this file to .env and adjust as needed — .env is loaded automatically
# (via dotenv) by the server, seed script, evals runner, and vitest configs.
# If port 5432 is already taken locally, set POSTGRES_PORT below AND update
# the port in DATABASE_URL / SEED_DATABASE_URL to match (docker compose also
# reads this same .env file for POSTGRES_PORT).
# POSTGRES_PORT=5432
DATABASE_URL=postgres://incident_ro:incident_ro@localhost:5432/incident
LOKI_URL=http://localhost:3100
STATEMENT_TIMEOUT_MS=5000
DEFAULT_ROW_LIMIT=100
MAX_ROW_LIMIT=1000
RESULT_TOKEN_BUDGET=4000
DB_POOL_SIZE=4
DB_IDLE_TIMEOUT_MS=30000
LOG_LEVEL=info

# LOKI_BASIC_AUTH=123456:glc_eyJ...
# LOKI_BEARER_TOKEN=...

SEED_DATABASE_URL=postgres://postgres:postgres@localhost:5432/incident

ANTHROPIC_API_KEY=sk-ant-...
# AGENT_MODEL=claude-opus-4-8
# JUDGE_MODEL=claude-opus-4-8
# TOOL_VARIANT=v2
